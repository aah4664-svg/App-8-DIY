 <body>
  <div data-role="page">
    <div data-role="header">
      <h1>LAMP Diagnostic App</h1>
    </div>
    
    <div data-role="content">	
      <div style="text-align:center;">
        <input type="file" id="fileInput" data-role="button" data-theme="b">
        <div id="messageDisplayArea">Ready for input.</div>
        <div id="resultArea" style="padding:10px; border:1px solid #ccc; margin-top:10px;">
          <h3>Results will appear here.</h3>
        </div>
      </div>
      
      <div style="display:flex; flex-wrap:wrap; justify-content:center; gap:10px; margin-top:20px;">
        <canvas id="myCanvas" width=600 height=500 style="border:1px solid #d3d3d3; max-width:100%; height:auto;"></canvas>
        <canvas id="dataCanvas" width=600 height=500 style="border:1px solid #d3d3d3; max-width:100%; height:auto;"></canvas> 
      </div>

    </div><!-- /content -->
    <div data-role="footer" data-position="fixed">
      <p>DIY Diagnostics</p>
    </div><!-- /footer -->
  </div><!-- /page -->
 </body>
</html>
