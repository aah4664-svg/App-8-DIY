    // Critical fix for iPhone "squashed" photos
    function drawImageIOSFix(ctx, img, sx, sy, sw, sh, dx, dy, dw, dh) {
      var canvas = document.createElement('canvas');
      canvas.width = 1; canvas.height = img.naturalHeight;
      var tctx = canvas.getContext('2d');
      tctx.drawImage(img, 0, 0);
      var data = tctx.getImageData(0, 0, 1, img.naturalHeight).data;
      var sy_f = 0, ey = img.naturalHeight, py = img.naturalHeight;
      while (py > sy_f) {
        if (data[(py - 1) * 4 + 3] === 0) { ey = py; } else { sy_f = py; }
        py = (ey + sy_f) >> 1;
      }
      var ratio = (py / img.naturalHeight) || 1;
      ctx.drawImage(img, sx, sy, sw, sh, dx, dy, dw, dh / ratio);
    }
    
